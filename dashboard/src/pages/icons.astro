---
import Layout from "../components/Layout.astro";
import GinsIcons from "../components/GinsIcons.preact";
import fs from "node:fs";
import path from "node:path";

let icons = [];
const catalogPath = path.resolve("public", "icons-catalog.json");

if (fs.existsSync(catalogPath)) {
    try {
        const data = fs.readFileSync(catalogPath, "utf-8");
        icons = JSON.parse(data);
    } catch (e) {
        console.error("Failed to parse icons-catalog.json", e);
    }
}
---

<Layout title="Gins Icon Hub | Premium Proxy Assets">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <GinsIcons client:load initialIcons={icons} />
  </div>
</Layout>
