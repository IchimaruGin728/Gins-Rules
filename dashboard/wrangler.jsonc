{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "gins-rules-dashboard",
  "compatibility_date": "2026-03-01",
  "pages_build_output_dir": "./dist",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "gins-rules-db",
      "database_id": "250676c5-78f0-49e6-a9c8-cec4a012e14e",
      "migrations_dir": "./migrations"
    }
  ]
}
